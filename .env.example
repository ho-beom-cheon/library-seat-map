# Backend
DATA_GO_KR_SERVICE_KEY=your_service_key_here
DATA_GO_KR_KEY_IS_ENCODED=false
PUBLIC_API_RESPONSE_TYPE=json
PUBLIC_API_BASE_URL=https://apis.data.go.kr/B551982/plr_v2

LIBRARY_SYNC_ENABLED=true
LIBRARY_SYNC_INFO_CRON=0 10 3 * * *
LIBRARY_SYNC_REALTIME_DELAY_MS=120000
LIBRARY_SYNC_OPERATION_STATUS_ENABLED=false
LIBRARY_SYNC_DISTRICTS=1168000000

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/libraryseat
SPRING_DATASOURCE_USERNAME=libraryseat
SPRING_DATASOURCE_PASSWORD=

REDIS_ENABLED=false
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

APP_LOCATION_LOGGING_ENABLED=false

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_MAP_PROVIDER=kakao
NEXT_PUBLIC_KAKAO_MAP_KEY=your_browser_key_here
